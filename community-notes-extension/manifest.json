{
  "manifest_version": 3,
  "name": "Community Notes",
  "version": "1.0",
  "description": "Transparent community notes on any webpage, by verified students",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "http://45.55.80.161/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
